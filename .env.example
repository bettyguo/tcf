# tcf-accel environment configuration — placeholders only.
# Copy to `.env` (gitignored) and fill in for local development.
# Every var read by the system is documented here; missing this docstring is a bug.

# ─── Database (docker-compose defaults match these) ────────────
DATABASE_URL=postgresql+asyncpg://tcf:tcf@localhost:5432/tcf
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Run Alembic migrations against a synchronous URL too (sometimes used by tooling)
DATABASE_URL_SYNC=postgresql://tcf:tcf@localhost:5432/tcf

# ─── LLM gateway (litellm) — see ADR-0009 ──────────────────────
# Default model per master prompt §8.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=                     # required for cloud LLM; leave blank for local-only
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Optional: point litellm at a local Ollama for Mistral / Llama variants
OLLAMA_BASE_URL=

# Temperature for the LLM critic. Master prompt + Phase 7 ADR-039 cap this at 0.2.
LLM_TEMPERATURE=0.2

# Cache directory for litellm response cache (Phase 7 uses heavily)
LLM_CACHE_DIR=.cache/litellm

# ─── ASR — see ADR-0007 ────────────────────────────────────────
# local | openai_api
ASR_PROVIDER=local
WHISPER_MODEL=bofenghuang/whisper-large-v3-french

# Confidence threshold — outputs below this raise ASRConfidenceTooLowError
ASR_MIN_CONFIDENCE=0.65

# ─── Privacy default — master prompt §6.4 ──────────────────────
# local_only | cloud_optin
PRIVACY_DEFAULT_MODE=local_only

# ─── Auth (Phase 2 will wire) ──────────────────────────────────
JWT_SECRET=please-change-me-this-is-a-development-placeholder
JWT_ACCESS_TTL_S=900                   # 15 min
JWT_REFRESH_TTL_S=2592000              # 30 days

# ─── Observability ─────────────────────────────────────────────
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                        # json | console
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=tcf-accel-api
PROMETHEUS_METRICS_PORT=9090

# Sampling rate for OpenTelemetry traces in production; 1.0 = 100%
OTEL_TRACE_SAMPLE_RATE=0.05

# ─── Worker / Celery ───────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=200  # cycling to dodge known memory leaks

# ─── Web (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=en          # en | fr | es | ar | zh

# ─── Content pipeline (Phase 3) ────────────────────────────────
CONTENT_BANK_PATH=./data/bank
INGEST_USER_AGENT=tcf-accel-ingest/0.1 (+https://github.com/tcf-accel)

# ─── Mock exam (Phase 6) ───────────────────────────────────────
# canonical | training
MOCK_EXAM_DEFAULT_MODE=canonical
