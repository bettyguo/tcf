root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown uses trailing spaces for hard breaks

[Makefile]
indent_style = tab
indent_size = 4

[*.{ps1,bat,cmd}]
end_of_line = crlf
